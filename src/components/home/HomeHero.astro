---
import HeroTerminal from '../HeroTerminal.tsx';
import type { TerminalProjectRow } from '../../utils/terminalCommands';

interface Props {
  terminalProjectRows: TerminalProjectRow[];
  bioLines: string[];
  introLines: string[];
  whoamiLine: string;
  knownSlugs: string[];
  openSectionTokens: Record<string, string>;
  sectionIds: string[];
}

const {
  terminalProjectRows,
  bioLines,
  introLines,
  whoamiLine,
  knownSlugs,
  openSectionTokens,
  sectionIds,
} = Astro.props;
---

<section class="hero-grid hero-grid--split section-pad home-hero">
  <div class="hero-copy">
    <div class="hero-eyebrow home-hero__eyebrow">
      <span class="home-hero__eyebrow-rule"></span>
      Senior Frontend Engineer
    </div>
    <h1 class="hero-h1">
      Saar<br/>Davidson.
    </h1>
    <p class="hero-lead home-hero__lead">
      I build frontend systems for complex products.
    </p>
    <p class="hero-lead home-hero__lead home-hero__lead--follow">
      Most of my work is around React, TypeScript, React Native, and product UI architecture. Recently, I’ve also been working more with AI-powered product flows.
    </p>
    <div class="home-hero__actions">
      <a href="#experience" class="home-hero__btn-primary">See selected work<span class="home-hero__btn-primary-arrow" aria-hidden="true">→</span></a>
      <a href="#contact" class="home-hero__btn-secondary">Contact me</a>
    </div>
  </div>
  <HeroTerminal
    client:load
    projects={terminalProjectRows}
    bioLines={bioLines}
    introLines={introLines}
    whoamiLine={whoamiLine}
    knownSlugs={knownSlugs}
    openSectionTokens={openSectionTokens}
    sectionIds={sectionIds}
  />
</section>
