---
interface Props {
  sinceCardLine: string;
}

const { sinceCardLine } = Astro.props;
---

<section id="about" class="about-grid section-pad home-about">
  <div>
    <div class="home-kicker">02 — about</div>
    <h2 class="section-h2">
      Product-minded.<br />
      Frontend-focused.<br />
      <span class="home-italic-muted">AI-aware.</span>
    </h2>
  </div>
  <div class="home-about__copy">
    <p>
      I’m a frontend engineer who works on complex product interfaces.
    </p>
    <p>
      I care about clear UX, maintainable architecture, good performance, and code that teams can keep working with.
    </p>
    <p>
      My core work is React, TypeScript, Next.js, and React Native.
    </p>
    <p>
      AI is part of my current direction, but not as a buzzword. I’m interested in how AI changes product UX, and how developers can use it to work faster without becoming less thoughtful.
    </p>
    <p class="home-about__foot">
      <a href="#beyond" class="home-about__inline-link">Beyond work</a>
    </p>
    <div class="about-cards home-about-cards">
      {[
        { k: '/now', v: 'Senior frontend engineering', dot: 'var(--accent)' },
        { k: '/since', v: sinceCardLine, dot: 'var(--cyan)' },
        { k: '/based', v: 'Ramat Gan, Israel', dot: 'var(--lime)' },
      ].map(({ k, v, dot }) => (
        <div class="home-about-card" style={`--about-dot: ${dot}`}>
          <div class="home-about-card__label">
            <span class="home-about-card__dot"></span>
            {k}
          </div>
          <div class="home-about-card__value">{v}</div>
        </div>
      ))}
    </div>
  </div>
</section>
