---
import '../styles/global.css';
import { shippingYearsProse } from '../utils/experience';

interface Props { title?: string; description?: string; }

const defaultDescription = `Saar Davidson is a frontend and AI product engineer based in Ramat Gan, Israel. ${shippingYearsProse()} shipping React, TypeScript, Next.js, Node.js, and LLM-powered product workflows.`;

const {
  title = "Saar Davidson — Frontend & AI Product Engineer",
  description = defaultDescription,
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,700;12..96,800;12..96,900&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="#main-content" class="skip-to-main">Skip to main content</a>
  <div class="blob-shell blob-shell--1" data-parallax="0.07" aria-hidden="true">
    <div class="blob-inner blob-inner--1"></div>
  </div>
  <div class="blob-shell blob-shell--2" data-parallax="0.11" aria-hidden="true">
    <div class="blob-inner blob-inner--2"></div>
  </div>
  <div class="blob-shell blob-shell--3" data-parallax="0.15" aria-hidden="true">
    <div class="blob-inner blob-inner--3"></div>
  </div>
  <slot />
  <script is:inline>
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const nodes = document.querySelectorAll('[data-parallax]');
      if (!nodes.length) return;
      let ticking = false;
      function apply() {
        const y = window.scrollY || window.pageYOffset;
        for (let i = 0; i < nodes.length; i++) {
          const el = nodes[i];
          const speed = parseFloat(el.getAttribute('data-parallax') || '0.1');
          el.style.transform = 'translate3d(0,' + Math.round(y * speed) + 'px,0)';
        }
        ticking = false;
      }
      function onScroll() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(apply);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      apply();
    })();
  </script>
</body>
</html>
