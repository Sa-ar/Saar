---
import { getEntry, render } from 'astro:content';
import { marked } from 'marked';
import CaseStudyShell from '../../components/CaseStudyShell.astro';
import { allCaseStudySlugs, projects } from '../../data/portfolio';

/**
 * Build `/work/:slug` only for slugs we actually link to from the site.
 * Params must match each markdown entry's collection `id` (see `src/content.config.ts`).
 */
export async function getStaticPaths() {
  return allCaseStudySlugs(projects).map((slug) => ({
    params: { slug },
  }));
}

const slug = Astro.params.slug;
if (!slug) {
  throw new Error('Case study page invoked without a slug param.');
}

const entry = await getEntry('caseStudies', slug);
if (!entry) {
  throw new Error(
    `Case study "${slug}" is listed in portfolio data but has no matching content entry. Add src/content/caseStudies/${slug}.md (frontmatter + body) or fix the slug so it matches the file-derived collection id.`,
  );
}

const { Content } = await render(entry);
const { title, description, eyebrow, h1, lead, navPrev, navNext } = entry.data;

const leadHtml = marked.parseInline(lead.trim(), { async: false }) as string;

const seriesNavClass =
  navPrev && navNext
    ? 'case-study-series-nav case-study-series-nav--split'
    : 'case-study-series-nav';
---

<CaseStudyShell title={title} description={description} eyebrow={eyebrow}>
  <h1 class="case-h1">{h1}</h1>
  <p class="case-study-lead" set:html={leadHtml} />
  <div class="case-study-prose">
    <Content />
  </div>

  {
    (navPrev || navNext) && (
      <p class={seriesNavClass}>
        {navPrev && (
          <a class="case-study-inline-link" href={navPrev.href}>
            {navPrev.label}
          </a>
        )}
        {navPrev && navNext && (
          <span class="case-study-series-nav__sep" aria-hidden="true">
            {' '}
            ·{' '}
          </span>
        )}
        {navNext && (
          <a class="case-study-inline-link" href={navNext.href}>
            {navNext.label}
          </a>
        )}
      </p>
    )
  }
</CaseStudyShell>
