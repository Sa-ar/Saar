---
import Layout from '../layouts/Layout.astro';
import NavClock from '../components/NavClock.tsx';
import StackShowcase from '../components/StackShowcase.tsx';
import HeroTerminal from '../components/HeroTerminal.tsx';
import {
  projects,
  heroTerminalBioLines,
  collectCaseStudySlugs,
  allCaseStudySlugs,
  siteSectionAnchors,
  sectionOpenTokenToId,
} from '../data/site';
import { shippingSinceCardLine, shippingYearsProse } from '../utils/experience';

const terminalProjectRows = projects.map((p) => ({
  title: p.title,
  year: p.year,
  tag: p.tag,
  role: p.role,
  caseStudySlugs: collectCaseStudySlugs(p),
}));

const heroTerminalSlugs = allCaseStudySlugs(projects);
const heroWhoamiLine =
  'saar — frontend engineer · AI product builder · Ramat Gan, IL';

const openSectionTokens = sectionOpenTokenToId();
const sectionIds = siteSectionAnchors.map((s) => s.id);

const skills = [
  { group: 'Foundations', items: ['TypeScript', 'JavaScript', 'Node.js', 'Python', 'CSS', 'Tailwind'] },
  { group: 'Frameworks', items: ['React', 'Next.js', 'Remix', 'React Native', 'Solid', 'Styled Components'] },
  { group: 'Build & APIs', items: ['Vite', 'Cypress', 'Turborepo', 'Storybook', 'GraphQL', 'REST', 'TanStack Start', 'DatoCMS'] },
  { group: 'AI product', items: ['LLM apps', 'RAG', 'Agents', 'pgvector', 'Prompt eval', 'TanStack Query', 'MobX'] },
];

const year = new Date().getFullYear();
const yearsShippingProse = shippingYearsProse();
const sinceCardLine = shippingSinceCardLine();

/** Long hero copy — read in the terminal via `cat intro`. */
const heroIntroTerminalLines = [
  'I build polished product interfaces and the AI workflows behind them — React, TypeScript, Next.js, Node.js, RAG, agents, and eval loops when the product needs them.',
  `${yearsShippingProse} shipping front-end systems across health, collaboration, logistics, and consulting. These days I’m especially interested in AI features that feel like product work, not demos: retrieval that earns trust, agents with visible boundaries, and interfaces that help people understand what the model is doing. The full thread lives in #work.`,
];

/** Off the clock — campus history and dance floor. */
const beyondBlocks = [
  {
    title: 'Founder — Colman Dev Club',
    body: 'Started and led the first official developer club at the College of Management, growing a community of hundreds of students around weekly workshops, practical projects, and the confidence to build in public.',
  },
  {
    title: 'Lead organizer — Hackathons',
    body: 'Led Colman Hack 2021 and MTA Hack 2019: large 24-hour build events with technical logistics, sponsorships, mentors, and hundreds of participants moving from idea to demo.',
  },
  {
    title: 'Zouk dancer & DJ',
    body: 'Away from the keyboard I social-dance Zouk and sometimes DJ for rooms I care about — reading a floor, building energy, and handing people a shared release at the end of a long week.',
  },
];
---
<Layout>
  <!-- NAV -->
  <nav class="site-nav section-pad" style="display:flex;justify-content:space-between;align-items:center;padding:28px 56px;border-bottom:1px solid rgba(248,241,255,.08);">
    <div class="nav-brand" style="display:flex;align-items:center;gap:12px;font-family:var(--font-mono);font-size:13px;letter-spacing:.15em;">
      <span class="nav-dot" style="width:10px;height:10px;border-radius:50%;background:var(--accent);box-shadow:0 0 12px var(--accent);display:inline-block;animation:pulse 2s ease-in-out infinite;"></span>
      SAAR DAVIDSON
    </div>
    <div class="nav-links nav-links--desktop" style="display:flex;gap:32px;font-family:var(--font-mono);font-size:12px;letter-spacing:.15em;text-transform:uppercase;">
      <a href="#about">about</a>
      <a href="#craft">craft</a>
      <a href="#work">work</a>
      <a href="#beyond">beyond</a>
      <a href="#stack">stack</a>
      <a href="#contact">contact</a>
    </div>
    <div class="nav-right" style="display:flex;align-items:center;gap:18px;">
      <span class="nav-clock-wrap">
        <NavClock client:load />
      </span>
      <button
        class="nav-hamburger"
        id="nav-hamburger"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
      >
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
      </button>
    </div>
    <div class="nav-links nav-links--mobile" id="nav-mobile-menu" data-open="false">
      <a href="#about">about</a>
      <a href="#craft">craft</a>
      <a href="#work">work</a>
      <a href="#beyond">beyond</a>
      <a href="#stack">stack</a>
      <a href="#contact">contact</a>
    </div>
  </nav>

  <script is:inline>
    (function () {
      const btn = document.getElementById('nav-hamburger');
      const menu = document.getElementById('nav-mobile-menu');
      if (!btn || !menu) return;
      const setOpen = function (open) {
        var wasOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(open));
        menu.setAttribute('data-open', String(open));
        if (open && !wasOpen) {
          requestAnimationFrame(function () {
            var link = menu.querySelector('a');
            if (link) link.focus();
          });
        } else if (!open && wasOpen) {
          btn.focus();
        }
      };
      btn.addEventListener('click', function () {
        setOpen(btn.getAttribute('aria-expanded') !== 'true');
      });
      menu.addEventListener('click', function (event) {
        if (event.target instanceof Element && event.target.closest('a')) {
          setOpen(false);
        }
      });
      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') setOpen(false);
      });
      var mq = window.matchMedia('(min-width: 821px)');
      var handleChange = function (e) { if (e.matches) setOpen(false); };
      if (mq.addEventListener) mq.addEventListener('change', handleChange);
      else mq.addListener(handleChange);
    })();
  </script>

  <main id="main-content" tabindex="-1">
  <!-- HERO -->
  <section class="hero-grid hero-grid--split section-pad" style="padding:72px 56px 100px;position:relative;z-index:1;">
    <div class="hero-copy">
      <div class="hero-eyebrow" style="font-family:var(--font-mono);font-size:12px;letter-spacing:.2em;color:var(--accent);margin-bottom:20px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <span style="width:30px;height:1px;background:var(--accent);display:inline-block;"></span>
        FRONTEND ENGINEER · AI PRODUCT BUILDER
      </div>
      <h1 class="hero-h1">
        Saar<br/>Davidson.
      </h1>
      <p class="hero-lead" style="font-family:var(--font-display);font-size:26px;line-height:1.3;margin-top:28px;max-width:540px;font-weight:500;">
        I build <span style="color:var(--accent);">polished product interfaces</span> and the AI workflows behind them — React, TypeScript, Next.js, Node.js, RAG, agents, and eval loops when the product needs them.
      </p>
      <div style="display:flex;gap:14px;margin-top:28px;flex-wrap:wrap;">
        <a href="#work" class="btn-primary" style="background:var(--accent);color:var(--bg);padding:14px 28px;font-family:var(--font-mono);font-size:12px;letter-spacing:.18em;text-transform:uppercase;border-radius:999px;text-decoration:none;font-weight:700;box-shadow:0 0 30px color-mix(in srgb,var(--accent) 40%,transparent);">
          see the work →
        </a>
        <a href="#contact" style="background:transparent;color:var(--ink);border:1px solid rgba(248,241,255,.3);padding:14px 28px;font-family:var(--font-mono);font-size:12px;letter-spacing:.18em;text-transform:uppercase;border-radius:999px;text-decoration:none;">
          get in touch
        </a>
      </div>
    </div>
    <HeroTerminal
      client:load
      projects={terminalProjectRows}
      bioLines={heroTerminalBioLines}
      introLines={heroIntroTerminalLines}
      whoamiLine={heroWhoamiLine}
      knownSlugs={heroTerminalSlugs}
      openSectionTokens={openSectionTokens}
      sectionIds={sectionIds}
    />
  </section>

  <!-- ABOUT -->
  <section id="about" class="about-grid section-pad" style="padding:120px 56px;display:grid;grid-template-columns:.8fr 1.4fr;gap:80px;position:relative;z-index:1;">
    <div>
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--accent);margin-bottom:16px;">01 — about</div>
      <h2 class="section-h2" style="font-family:var(--font-display);font-size:56px;font-weight:700;line-height:.98;margin:0;letter-spacing:-.03em;">
        Product-minded.<br/>
        <span style="font-style:italic;font-weight:400;opacity:.6;">AI-curious.</span><br/>
        Frontend at heart.
      </h2>
    </div>
    <div style="font-size:18px;line-height:1.7;color:rgba(248,241,255,.82);">
      <p style="margin-top:0;">
        I’m a frontend engineer based in Ramat Gan. Day to day I work in <strong style="color:var(--ink);">React, TypeScript, Next.js, Remix, and Node.js</strong> — building interfaces that feel fast, systems that stay readable, and developer experience that does not fight the people using it.
      </p>
      <p>
        Lately that has expanded into <strong style="color:var(--ink);">AI-powered product work</strong>: retrieval pipelines, agentic workflows, prompt evaluation, and UI patterns that make LLM behavior understandable instead of magical. I have a CS degree from the College of Management, a bias for useful systems over shiny demos, and <a href="#beyond" style="color:var(--accent);text-decoration:underline;text-underline-offset:3px;">life around the keyboard</a> that keeps the work human.
      </p>
      <div class="about-cards" style="margin-top:36px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
        {[
          { k: '/now',   v: 'Frontend + AI product engineering', dot: 'var(--accent)' },
          { k: '/since', v: sinceCardLine, dot: 'var(--cyan)' },
          { k: '/based', v: 'Ramat Gan, Israel',             dot: 'var(--lime)'   },
        ].map(({ k, v, dot }) => (
          <div style="padding:16px;background:var(--panel);border:1px solid rgba(248,241,255,.1);border-radius:10px;">
            <div style={`font-family:var(--font-mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--dim);display:flex;align-items:center;gap:8px;`}>
              <span style={`width:6px;height:6px;background:${dot};border-radius:50%;box-shadow:0 0 8px ${dot};display:inline-block;flex-shrink:0;`}></span>
              {k}
            </div>
            <div style="font-size:14px;margin-top:6px;line-height:1.4;">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CRAFT: principles + AI product notes -->
  <section
    id="craft"
    class="section-pad"
    style="padding:100px 56px 120px;position:relative;z-index:1;border-top:1px solid rgba(248,241,255,.08);"
  >
    <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--accent);margin-bottom:16px;">02 — craft</div>
    <h2 class="section-h2" style="font-family:var(--font-display);font-size:56px;font-weight:700;line-height:.98;margin:0 0 28px;letter-spacing:-.03em;">
      how I make AI products <span style="font-style:italic;font-weight:400;opacity:.6;">feel real.</span>
    </h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;" class="craft-grid">
      <div>
        <p style="font-family:var(--font-mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--dim);margin:0 0 14px;">Principles</p>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:18px;font-size:17px;line-height:1.65;color:rgba(248,241,255,.88);">
          <li style="display:flex;gap:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--accent);flex-shrink:0;margin-top:2px;">01</span>
            <span><strong style="color:var(--ink);">Start from the product moment.</strong> Before choosing tools, get clear on the user job, the trust boundary, and what a bad answer or broken flow would cost.</span>
          </li>
          <li style="display:flex;gap:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--accent);flex-shrink:0;margin-top:2px;">02</span>
            <span><strong style="color:var(--ink);">Make behavior observable.</strong> Baseline flows, data, errors, and regressions. For AI work, add eval examples and feedback loops so quality is not just a feeling.</span>
          </li>
          <li style="display:flex;gap:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--accent);flex-shrink:0;margin-top:2px;">03</span>
            <span><strong style="color:var(--ink);">Keep interfaces legible.</strong> UI state, async work, model uncertainty, and fallback paths should be visible enough that users know what is happening and engineers can debug it later.</span>
          </li>
        </ul>
      </div>
      <div>
        <p style="font-family:var(--font-mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--dim);margin:0 0 14px;">AI product focus</p>
        <div style="margin-top:8px;padding:28px 26px 26px;border-radius:14px;border:1px solid rgba(248,241,255,.12);background:rgba(248,241,255,.03);max-width:720px;">
          <p style="margin:0 0 18px;font-size:15px;line-height:1.65;color:var(--dim);">
            The AI work I care about is not “add a chat box.” It is the product layer around the model: what context it sees, how users recover when it is wrong, and how the team knows whether behavior is getting better.
          </p>
          <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:14px;font-size:15px;line-height:1.6;color:rgba(248,241,255,.86);">
            <li><strong style="color:var(--ink);">Retrieval people can trust:</strong> sources, scope, freshness, and enough UI context to understand where an answer came from.</li>
            <li><strong style="color:var(--ink);">Agents with boundaries:</strong> clear permissions, visible progress, graceful stops, and handoffs when automation should not guess.</li>
            <li><strong style="color:var(--ink);">Evals that stay close to users:</strong> small, concrete test sets from real tasks instead of abstract benchmark theater.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" class="section-pad" style="padding:40px 56px 120px;position:relative;z-index:1;">
    <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--accent);margin-bottom:16px;">03 — selected work · newest → oldest</div>
    <h2 class="section-h2" style="font-family:var(--font-display);font-size:56px;font-weight:700;line-height:.98;margin:0 0 48px;letter-spacing:-.03em;">
      product systems I've <span style="font-style:italic;font-weight:400;opacity:.6;">shipped.</span>
    </h2>
    <div>
      {projects.map((p, i) => (
        <article class="project-card">
          <div style="font-family:var(--font-mono);font-size:12px;color:var(--dim);letter-spacing:.1em;">
            ({String(i + 1).padStart(2, '0')})
          </div>
          <div>
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:8px;display:flex;gap:12px;flex-wrap:wrap;">
              <span>{p.tag}</span>
              <span style="color:var(--dim);">·</span>
              <span style="color:var(--dim);">{p.role}</span>
              <span style="color:var(--dim);">·</span>
              <span style="color:var(--dim);">{p.year}</span>
            </div>
            <h3 class="project-title">{p.title}</h3>
            {'sections' in p && Array.isArray(p.sections) ? (
              <div style="margin-top:12px;display:flex;flex-direction:column;gap:16px;max-width:680px;">
                {p.sections.map((sec) => (
                  <div>
                    <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:6px;">
                      {sec.heading}
                    </div>
                    <p style="font-size:15px;color:var(--dim);margin:0;line-height:1.55;">{sec.text}</p>
                    {'caseStudySlug' in sec && sec.caseStudySlug ? (
                      <p style="margin:10px 0 0;">
                        <a
                          class="case-study-inline-link"
                          href={`/work/${sec.caseStudySlug}`}
                        >
                          Read case study →
                        </a>
                      </p>
                    ) : null}
                  </div>
                ))}
              </div>
            ) : (
              <div style="margin-top:10px;max-width:680px;">
                <p style="font-size:15px;color:var(--dim);margin:0;line-height:1.55;">{'blurb' in p ? p.blurb : ''}</p>
                {'caseStudySlug' in p && p.caseStudySlug ? (
                  <p style="margin:10px 0 0;">
                    <a
                      class="case-study-inline-link"
                      href={`/work/${p.caseStudySlug}`}
                    >
                      Read case study →
                    </a>
                  </p>
                ) : null}
              </div>
            )}
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;">
              {p.stack.map(s => (
                <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:.1em;color:var(--dim);padding:3px 8px;border-radius:4px;background:rgba(248,241,255,.05);border:1px solid rgba(248,241,255,.08);">{s}</span>
              ))}
            </div>
          </div>
          <div class="project-arrow" aria-hidden="true">↗</div>
        </article>
      ))}
      <div style="border-top:1px solid rgba(248,241,255,.12);"></div>
    </div>
  </section>

  <!-- BEYOND WORK -->
  <section
    id="beyond"
    class="section-pad beyond-section"
    style="padding:120px 56px;position:relative;z-index:1;background:var(--panel);border-top:1px solid rgba(248,241,255,.08);border-bottom:1px solid rgba(248,241,255,.08);"
  >
    <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--accent);margin-bottom:16px;">04 — beyond work</div>
    <h2 class="section-h2" style="font-family:var(--font-display);font-size:56px;font-weight:700;line-height:.98;margin:0 0 40px;letter-spacing:-.03em;">
      life around the <span style="font-style:italic;font-weight:400;opacity:.6;">keyboard.</span>
    </h2>
    <div
      class="beyond-grid"
      style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:40px 48px;max-width:1100px;"
    >
      {beyondBlocks.map((block) => (
        <div>
          <h3 style="font-family:var(--font-display);font-size:26px;font-weight:700;margin:0 0 12px;letter-spacing:-.02em;color:var(--ink);">
            {block.title}
          </h3>
          <p style="font-size:17px;line-height:1.65;color:var(--dim);margin:0;">
            {block.body}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- STACK -->
  <section id="stack" class="section-pad" style="padding:120px 56px;position:relative;z-index:1;border-top:1px solid rgba(248,241,255,.08);border-bottom:1px solid rgba(248,241,255,.08);">
    <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--accent);margin-bottom:16px;">05 — stack</div>
    <h2 class="section-h2" style="font-family:var(--font-display);font-size:56px;font-weight:700;line-height:.98;margin:0 0 48px;letter-spacing:-.03em;">
      tools of the <span style="font-style:italic;font-weight:400;opacity:.6;">trade.</span>
    </h2>
    <StackShowcase client:visible skills={skills} />
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section-pad" style="padding:120px 56px 140px;position:relative;z-index:1;text-align:center;">
    <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--accent);margin-bottom:20px;">06 — get in touch</div>
    <h2 class="contact-h2" style="font-family:var(--font-display);font-size:88px;font-weight:700;line-height:.92;margin:0 auto;letter-spacing:-.04em;max-width:1100px;">
      building an AI product?<br/>
      let’s make it <span style="color:var(--accent);">usable.</span>
    </h2>
    <p style="font-size:17px;color:var(--dim);margin-top:24px;max-width:560px;margin-left:auto;margin-right:auto;">
      Open to senior frontend and product-engineering roles, AI-product collaborations, and consulting around interface quality, design systems, DX, and LLM-powered workflows. LinkedIn is the best place to start.
    </p>
    <div class="contact-cta-block">
      <div class="contact-cta-head">
        <span class="contact-cta-dot" aria-hidden="true"></span>
        <span>Primary channel</span>
      </div>
      <a
        href="https://www.linkedin.com/in/saar-davidson/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link contact-link--linkedin"
      >
        <span class="linkedin-btn__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" focusable="false">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </span>
        <span class="linkedin-btn__text">
          <span class="linkedin-btn__label">LinkedIn</span>
          <span class="linkedin-btn__handle">in/saar-davidson</span>
        </span>
      </a>
    </div>
  </section>
  </main>

  <!-- FOOTER -->
  <footer class="section-pad site-footer" style="padding:32px 56px;border-top:1px solid rgba(248,241,255,.08);display:flex;justify-content:space-between;align-items:center;font-family:var(--font-mono);font-size:11px;letter-spacing:.15em;color:var(--dim);position:relative;z-index:1;gap:16px;flex-wrap:wrap;">
    <div>© {year} SAAR DAVIDSON</div>
    <div class="footer-meta" style="display:flex;gap:20px;align-items:center;flex-wrap:wrap;">
      <span>v1.0</span>
      <span>BUILD 2026.05</span>
      <span style="display:flex;align-items:center;gap:6px;">
        <span style="width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s ease-in-out infinite;display:inline-block;"></span>
        ONLINE
      </span>
    </div>
  </footer>
</Layout>
